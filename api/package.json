{
	"name": "api",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun --watch index.ts",
		"start": "bun index.ts",
		"typecheck": "tsc --noEmit",
		"build": "bun run typecheck && bun build index.ts --outdir dist --target bun --sourcemap=external",
		"start:prod": "bun dist/index.js",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/bun": "latest",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/express-mongo-sanitize": "^2.1.2",
		"bun-types": "^1.3.11",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"prettier": "^3.8.1",
		"typescript-eslint": "^8.58.0"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@clerk/express": "^2.0.8",
		"cors": "^2.8.6",
		"dotenv": "^17.4.1",
		"express": "^5.2.1",
		"express-mongo-sanitize": "^2.2.0",
		"express-rate-limit": "^8.3.2",
		"helmet": "^8.1.0",
		"http-status-codes": "^2.3.0",
		"mongoose": "^9.4.1",
		"socket.io": "^4.8.3"
	}
}
